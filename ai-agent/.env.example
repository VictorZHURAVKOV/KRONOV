# === Скопируйте в .env и заполните реальными значениями ===

# Anthropic API ключ. Получить: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Модель Claude. Оставьте Sonnet 4.6 — лучший баланс цена/качество для русского диалога.
CLAUDE_MODEL=claude-sonnet-4-6

# Telegram-бот Андрея (сам агент в Telegram). Получить: @BotFather → /newbot
TELEGRAM_BOT_TOKEN=

# Куда слать уведомления "горячий лид готов". Chat ID Алёны или группы отдела продаж.
# Как узнать chat_id: @userinfobot в Telegram.
ALENA_TELEGRAM_CHAT_ID=
ALENA_PHONE=+375296888629
ALENA_NAME=Алёна

# Сайт
SITE_URL=https://kronov.by
SITE_ORIGIN=https://kronov.by

# Хост для запуска backend
HOST=0.0.0.0
PORT=8000

# CORS: какие домены могут обращаться к /chat (через запятую). Для локальной разработки — *
CORS_ORIGINS=https://kronov.by,http://localhost:8000,http://127.0.0.1:8000

# === Wazzup24 (SaaS-прослойка для WhatsApp/Viber/Instagram/VK/Авито) ===
# ID аккаунта (видно в левом верхнем углу кабинета Wazzup).
WAZZUP_ACCOUNT_ID=
# apiKey из раздела "Интеграция с CRM" → "Свой CRM / API" → сгенерировать ключ.
WAZZUP_API_KEY=
